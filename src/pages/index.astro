    <!-- FLOAT WHATSAPP -->
    <a class="float-wa" href="https://wa.me/5511942891718" target="_blank" rel="noreferrer" aria-label="Enviar mensagem no WhatsApp">💬</a>

    <script>
      const serviceNames = { banho:'Banho completo', tosa:'Tosa higiênica e da raça', hidratacao:'Hidratação capilar', consulta:'Consulta veterinária', spa:'Pacote Spa Pet', hotel:'Hotelzinho e creche' };
      const sizeNames = { pequeno:'Pequeno', medio:'Médio', grande:'Grande' };
      const extraNames = { unhas:'Corte de unhas', ouvidos:'Limpeza de ouvidos', dental:'Escovação dental', perfume:'Perfumação premium' };
      const whatsappNumber = '5511942891718';

      const state = {
        step: 0,
        services: [],
        size: 'pequeno',
        sizeMult: 1,
        extras: [],
        tutor: '',
        pet: '',
        date: '',
        note: ''
      };
      const totalSteps = 6;

      const wizard = document.getElementById('wizard');
      const panels = wizard.querySelectorAll('.step-panel');
      const dots = wizard.querySelectorAll('.step-dot');
      const lines = wizard.querySelectorAll('.step-line');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const sendBtn = document.getElementById('sendBtn');
      const serviceHint = document.getElementById('serviceHint');
      const reviewsCarousel = document.getElementById('reviewsCarousel');
      const reviewsPrev = document.getElementById('reviewsPrev');
      const reviewsNext = document.getElementById('reviewsNext');
      let reviewsAutoplayTimer = null;

      function brl(v) {
        return v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
      }

      function selectedServicesValue() {
        return state.services.reduce((acc, item) => acc + item.price, 0);
      }

      function calcTotal() {
        const extrasTotal = state.extras.reduce((a, e) => a + e.price, 0);
        return Math.round((selectedServicesValue() * state.sizeMult + extrasTotal) * 100) / 100;
      }

      function selectedServiceNames() {
        return state.services.map((item) => serviceNames[item.id]);
      }

      function selectedExtrasNames() {
        return state.extras.map((item) => extraNames[item.id]);
      }

      function updateStepper() {
        dots.forEach((dot, i) => {
          dot.classList.remove('active', 'done');
          if (i < state.step) dot.classList.add('done');
          else if (i === state.step) dot.classList.add('active');
        });
        lines.forEach((line, i) => {
          line.classList.toggle('active', i < state.step);
        });
      }

      function syncNavButtons() {
        prevBtn.style.display = state.step > 0 ? '' : 'none';
        nextBtn.style.display = state.step < totalSteps - 1 ? '' : 'none';
        sendBtn.style.display = state.step === totalSteps - 1 ? '' : 'none';
      }

      function showPanel() {
        panels.forEach((panel, i) => panel.classList.toggle('active', i === state.step));
        syncNavButtons();
        wizard.querySelector('.wizard-body').scrollTo({ top: 0, behavior: 'smooth' });
        if (state.step === totalSteps - 1) renderSummary();
      }

      function validateStep() {
        if (state.step === 0) {
          const ok = state.services.length > 0;
          serviceHint.classList.toggle('error', !ok);
          serviceHint.textContent = ok
            ? `${state.services.length} serviço(s) selecionado(s).`
            : 'Selecione pelo menos 1 serviço para continuar.';
          return ok;
        }

        if (state.step === 3) {
          const tutorInput = document.getElementById('tutor');
          const petInput = document.getElementById('pet');
          if (!tutorInput.value.trim()) {
            tutorInput.reportValidity();
            tutorInput.focus();
            return false;
          }
          if (!petInput.value.trim()) {
            petInput.reportValidity();
            petInput.focus();
            return false;
          }
          state.tutor = tutorInput.value.trim();
          state.pet = petInput.value.trim();
          return true;
        }

        if (state.step === 4) {
          const dateInput = document.getElementById('date');
          const noteInput = document.getElementById('note');
          if (!dateInput.value) {
            dateInput.reportValidity();
            dateInput.focus();
            return false;
          }
          state.date = dateInput.value;
          state.note = noteInput.value.trim();
          return true;
        }

        return true;
      }

      function goNext() {
        if (!validateStep()) return;
        if (state.step < totalSteps - 1) {
          state.step += 1;
          updateStepper();
          showPanel();
        }
      }

      function goPrev() {
        if (state.step > 0) {
          state.step -= 1;
          updateStepper();
          showPanel();
        }
      }

      function buildWhatsappMessage(total) {
        const servicesText = selectedServiceNames().length ? selectedServiceNames().join(', ') : 'Nenhum';
        const extrasText = selectedExtrasNames().length ? selectedExtrasNames().join(', ') : 'Nenhum';
        const noteText = state.note || 'Sem observações';

        return [
          'Oi! Vim pelo site do Cão de Estrelas 🐾',
          `Tutor(a): ${state.tutor}`,
          `Pet: ${state.pet}`,
          `Serviços: ${servicesText}`,
          `Porte: ${sizeNames[state.size]}`,
          `Extras: ${extrasText}`,
          `Data desejada: ${state.date}`,
          `Observações: ${noteText}`,
          `Valor estimado: ${brl(total)}`
        ].join('\n');
      }

      function renderLiveSummary() {
        const total = calcTotal();
        const servicesText = selectedServiceNames().length ? selectedServiceNames().join(', ') : 'Nenhum selecionado';
        const extrasText = selectedExtrasNames().length ? selectedExtrasNames().join(', ') : 'Nenhum';
        const noteText = state.note || 'Sem';

        document.getElementById('liveTotal').textContent = brl(total);
        document.getElementById('liveServices').textContent = servicesText;
        document.getElementById('liveSize').textContent = sizeNames[state.size];
        document.getElementById('liveExtras').textContent = extrasText;
        document.getElementById('liveNote').textContent = noteText;

        const tags = document.getElementById('liveServiceTags');
        tags.innerHTML = '';
        state.services.forEach((item) => {
          const tag = document.createElement('span');
          tag.className = 'tag';
          tag.textContent = serviceNames[item.id];
          tags.appendChild(tag);
        });

        if (state.step === totalSteps - 1) {
          const msg = buildWhatsappMessage(total);
          sendBtn.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(msg)}`;
        }
      }

      function renderSummary() {
        const total = calcTotal();
        document.getElementById('summaryPrice').textContent = brl(total);

        const list = document.getElementById('summaryItems');
        list.innerHTML = '';

        state.services.forEach((service) => {
          const li = document.createElement('li');
          li.innerHTML = `<span class="item-label">${serviceNames[service.id]}</span><span class="item-value">${brl(service.price * state.sizeMult)}</span>`;
          list.appendChild(li);
        });

        const sizeLi = document.createElement('li');
        sizeLi.innerHTML = `<span class="item-label">Porte ${sizeNames[state.size]}</span><span class="item-value">${state.sizeMult === 1 ? 'Incluso' : `+${Math.round((state.sizeMult - 1) * 100)}%`}</span>`;
        list.appendChild(sizeLi);

        state.extras.forEach((extra) => {
          const li = document.createElement('li');
          li.innerHTML = `<span class="item-label">${extraNames[extra.id]}</span><span class="item-value">${brl(extra.price)}</span>`;
          list.appendChild(li);
        });

        const msg = buildWhatsappMessage(total);
        sendBtn.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(msg)}`;
        renderLiveSummary();
      }

      function activateKeyboard(containerId, selector) {
        const container = document.getElementById(containerId);
        container.addEventListener('keydown', (event) => {
          const card = event.target.closest(selector);
          if (!card) return;
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            card.click();
          }
        });
      }

      function scrollReviews(direction) {
        const card = reviewsCarousel.querySelector('.quote-card');
        const step = card ? card.getBoundingClientRect().width + 20 : 320;
        reviewsCarousel.scrollBy({ left: direction * step, behavior: 'smooth' });
      }

      function autoplayReviewsStep() {
        const maxScroll = reviewsCarousel.scrollWidth - reviewsCarousel.clientWidth;
        const nearEnd = reviewsCarousel.scrollLeft >= maxScroll - 10;
        if (nearEnd) {
          reviewsCarousel.scrollTo({ left: 0, behavior: 'smooth' });
          return;
        }
        scrollReviews(1);
      }

      function stopReviewsAutoplay() {
        if (reviewsAutoplayTimer) {
          clearInterval(reviewsAutoplayTimer);
          reviewsAutoplayTimer = null;
        }
      }

      function startReviewsAutoplay() {
        stopReviewsAutoplay();
        if (!window.matchMedia('(max-width: 640px)').matches) return;
        reviewsAutoplayTimer = setInterval(autoplayReviewsStep, 3600);
      }

      nextBtn.addEventListener('click', goNext);
      prevBtn.addEventListener('click', goPrev);
      reviewsNext.addEventListener('click', () => scrollReviews(1));
      reviewsPrev.addEventListener('click', () => scrollReviews(-1));
      reviewsCarousel.addEventListener('touchstart', stopReviewsAutoplay, { passive: true });
      reviewsCarousel.addEventListener('pointerdown', stopReviewsAutoplay);
      reviewsCarousel.addEventListener('mouseenter', stopReviewsAutoplay);
      reviewsCarousel.addEventListener('mouseleave', startReviewsAutoplay);
      window.addEventListener('resize', startReviewsAutoplay, { passive: true });

      const reviewsDots = document.getElementById('reviewsDots');
      const reviewCards = reviewsCarousel.querySelectorAll('.quote-card');
      reviewCards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.classList.add('carousel-dot');
        dot.type = 'button';
        dot.setAttribute('aria-label', `Avaliação ${i + 1}`);
        if (i === 0) dot.classList.add('active');
        dot.addEventListener('click', () => {
          const card = reviewsCarousel.querySelector('.quote-card');
          const step = card ? card.getBoundingClientRect().width + 20 : 320;
          reviewsCarousel.scrollTo({ left: i * step, behavior: 'smooth' });
          stopReviewsAutoplay();
        });
        reviewsDots.appendChild(dot);
      });

      function updateDots() {
        const card = reviewsCarousel.querySelector('.quote-card');
        if (!card) return;
        const step = card.getBoundingClientRect().width + 20;
        const idx = Math.round(reviewsCarousel.scrollLeft / step);
        reviewsDots.querySelectorAll('.carousel-dot').forEach((d, i) => {
          d.classList.toggle('active', i === idx);
        });
      }

      reviewsCarousel.addEventListener('scroll', updateDots, { passive: true });
      window.addEventListener('resize', updateDots, { passive: true });

      document.getElementById('servicePicker').addEventListener('click', (event) => {
        const option = event.target.closest('.service-option');
        if (!option) return;

        const id = option.dataset.service;
        const price = Number(option.dataset.price || 0);
        const existingIndex = state.services.findIndex((item) => item.id === id);

        if (existingIndex >= 0) {
          state.services.splice(existingIndex, 1);
          option.classList.remove('selected');
          option.setAttribute('aria-pressed', 'false');
        } else {
          state.services.push({ id, price });
          option.classList.add('selected');
          option.setAttribute('aria-pressed', 'true');
        }

        validateStep();
        renderLiveSummary();
      });

      document.getElementById('sizePicker').addEventListener('click', (event) => {
        const option = event.target.closest('.size-option');
        if (!option) return;

        document.querySelectorAll('.size-option').forEach((item) => {
          item.classList.remove('selected');
          item.setAttribute('aria-pressed', 'false');
        });

        option.classList.add('selected');
        option.setAttribute('aria-pressed', 'true');
        state.size = option.dataset.size;
        state.sizeMult = Number(option.dataset.mult);
        renderLiveSummary();
      });

      document.getElementById('extraChips').addEventListener('click', (event) => {
        const chip = event.target.closest('.extra-chip');
        if (!chip) return;

        chip.classList.toggle('selected');
        const selected = chip.classList.contains('selected');
        chip.setAttribute('aria-pressed', String(selected));

        const id = chip.dataset.extraId;
        const price = Number(chip.dataset.extraPrice || 0);

        if (selected) {
          if (!state.extras.some((item) => item.id === id)) state.extras.push({ id, price });
        } else {
          state.extras = state.extras.filter((item) => item.id !== id);
        }

        renderLiveSummary();
      });

      ['tutor', 'pet', 'date'].forEach((id) => {
        const input = document.getElementById(id);
        input.addEventListener('input', () => {
          if (id === 'tutor') state.tutor = input.value.trim();
          if (id === 'pet') state.pet = input.value.trim();
          if (id === 'date') state.date = input.value;
          renderLiveSummary();
        });
      });

      const noteInput = document.getElementById('note');
      noteInput.addEventListener('input', () => {
        state.note = noteInput.value.trim();
        renderLiveSummary();
      });

      activateKeyboard('servicePicker', '.service-option');
      activateKeyboard('sizePicker', '.size-option');
      activateKeyboard('extraChips', '.extra-chip');

      // Header scroll effect
      const header = document.getElementById('siteHeader');
      window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });

      // Year
      document.getElementById('year').textContent = new Date().getFullYear();

      // Reveal animation
      const revealEls = document.querySelectorAll('.reveal');
      const revealObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      revealEls.forEach((el) => revealObs.observe(el));

      validateStep();
      updateStepper();
      showPanel();
      renderLiveSummary();
      startReviewsAutoplay();
    </script>
  </body>
</html>

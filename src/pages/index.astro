---
const siteUrl = 'https://www.caodeestrelas.com.br';
const pageUrl = `${siteUrl}/`;
const ogImage = 'https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_1200,h_960,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png';

const services = [
  { id: 'banho', name: 'Banho completo', emoji: '🛁', desc: 'Limpeza profunda, secagem cuidadosa e finalização cheirosa.', price: 45 },
  { id: 'tosa', name: 'Tosa higiênica e da raça', emoji: '✂️', desc: 'Máquina ou tesoura, respeitando o conforto e estilo do seu pet.', price: 55 },
  { id: 'hidratacao', name: 'Hidratação capilar', emoji: '💧', desc: 'Tratamento para pelagem macia, brilhante e com menos nós.', price: 65 },
  { id: 'consulta', name: 'Consulta veterinária', emoji: '🩺', desc: 'Avaliação clínica com orientação preventiva para cada fase de vida.', price: 120 },
  { id: 'spa', name: 'Pacote Spa Pet', emoji: '🧴', desc: 'Banho premium + hidratação + perfume suave e escovação especial.', price: 140 },
  { id: 'hotel', name: 'Hotelzinho e creche', emoji: '🏨', desc: 'Ambiente seguro, recreação monitorada e rotina de carinho.', price: 95 },
];

const extras = [
  { id: 'unhas', name: 'Corte de unhas', price: 15, emoji: '💅' },
  { id: 'ouvidos', name: 'Limpeza de ouvidos', price: 15, emoji: '👂' },
  { id: 'dental', name: 'Escovação dental', price: 20, emoji: '🦷' },
  { id: 'perfume', name: 'Perfumação premium', price: 10, emoji: '🌸' },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'PetStore',
  name: 'Cão de Estrelas Pet Shop',
  url: pageUrl,
  image: ogImage,
  telephone: '+5511942891718',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rua Gaivota, 903',
    addressLocality: 'Moema',
    addressRegion: 'SP',
    postalCode: '04522-031',
    addressCountry: 'BR'
  },
  sameAs: ['https://www.instagram.com/caodeestrelas/'],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '249'
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Quais serviços o Cão de Estrelas oferece?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Banho, tosa, hidratação, consulta veterinária, spa pet, hotelzinho e creche.'
      }
    },
    {
      '@type': 'Question',
      name: 'Vocês atendem Schnauzer, Spitz e Golden?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. A equipe é especialista em Schnauzer, Spitz Alemão e Golden Retriever.'
      }
    },
    {
      '@type': 'Question',
      name: 'Onde fica o pet shop?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Rua Gaivota, 903 - Moema, São Paulo - SP, CEP 04522-031.'
      }
    },
    {
      '@type': 'Question',
      name: 'Como agendar atendimento?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Você pode usar o simulador da página ou chamar no WhatsApp (11) 94289-1718.'
      }
    }
  ]
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cão de Estrelas Pet Shop em Moema | Banho, Tosa, Veterinário e Hidratação</title>
    <meta name="description" content="Pet Shop Cão de Estrelas em Moema: banho, tosa, hidratação, consulta veterinária e atendimento especializado em Schnauzer, Spitz e Golden." />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="theme-color" content="#0d9488" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Cão de Estrelas Pet Shop" />
    <meta property="og:title" content="Cão de Estrelas Pet Shop em Moema | Banho, Tosa, Veterinário e Hidratação" />
    <meta property="og:description" content="Banho, tosa, hidratação, consulta veterinária e atendimento especializado em Schnauzer, Spitz e Golden." />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Cão de Estrelas Pet Shop" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Cão de Estrelas Pet Shop em Moema" />
    <meta name="twitter:description" content="Banho, tosa, hidratação, consulta veterinária e especialistas em Schnauzer, Spitz e Golden." />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      :root {
        --c1: #0d9488;
        --c1-light: #ccfbf1;
        --c1-dark: #065f52;
        --c2: #f97316;
        --c2-light: #fff7ed;
        --c3: #fbbf24;
        --ink: #1a2e35;
        --muted: #4b6a74;
        --card: #ffffff;
        --bg: #f8fffe;
        --radius: 20px;
        --radius-lg: 28px;
        --shadow-sm: 0 2px 8px rgba(13,148,136,0.06);
        --shadow: 0 8px 30px rgba(13,148,136,0.10);
        --shadow-lg: 0 20px 50px rgba(13,148,136,0.14);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; }
      html { scroll-behavior: smooth; overflow-x: clip; max-width: 100%; }

      body {
        font-family: 'Nunito', sans-serif;
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        overflow-x: clip;
        max-width: 100%;
      }

      img, iframe, video, svg {
        max-width: 100%;
      }

      main, section, header, footer {
        max-width: 100%;
        overflow-x: clip;
      }

      .container { width: min(1200px, calc(100% - 32px)); margin: 0 auto; }

      /* ===== HEADER ===== */
      .site-header {
        position: sticky; top: 0; z-index: 50;
        backdrop-filter: blur(16px) saturate(1.4);
        -webkit-backdrop-filter: blur(16px) saturate(1.4);
        background: rgba(248,255,254,0.82);
        border-bottom: 1px solid rgba(13,148,136,0.08);
        transition: box-shadow 0.3s;
      }
      .site-header.scrolled { box-shadow: var(--shadow-sm); }
      .site-header .container {
        display: flex; align-items: center; justify-content: space-between;
        min-height: 68px; gap: 12px;
      }
      .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ink); }
      .logo-icon {
        width: 44px; height: 44px; border-radius: 14px; display: grid; place-items: center;
        overflow: hidden; background: #fff; box-shadow: 0 6px 16px rgba(13,148,136,0.18);
        border: 1px solid rgba(13,148,136,0.12);
      }
      .logo-icon img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .brand-text { font-family: 'Baloo 2', cursive; font-size: 1.35rem; }
      .brand-text span { color: var(--c1); }

      .menu { display: flex; align-items: center; gap: 6px; }
      .menu a {
        text-decoration: none; color: var(--muted); font-weight: 700; font-size: 0.9rem;
        padding: 8px 14px; border-radius: 10px; transition: all 0.2s;
      }
      .menu a:hover { color: var(--c1); background: var(--c1-light); }

      .btn {
        border: 0; border-radius: 999px; padding: 12px 24px; font-size: 0.95rem;
        font-weight: 800; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
        font-family: inherit;
      }
      .btn:hover { transform: translateY(-2px); filter: saturate(1.05); }
      .btn:active { transform: translateY(0); }
      .btn-primary {
        color: #fff; background: linear-gradient(135deg, var(--c1), #2dd4bf);
        box-shadow: 0 8px 20px rgba(13,148,136,0.25);
      }
      .btn-primary:hover { box-shadow: 0 12px 28px rgba(13,148,136,0.35); }
      .btn-secondary {
        color: #064e4b; background: #d9fffb; border: 2px solid rgba(13,148,136,0.12);
        box-shadow: 0 8px 16px rgba(13,148,136,0.08);
      }
      .btn-secondary:hover { border-color: var(--c1); box-shadow: 0 12px 24px rgba(13,148,136,0.15); }
      .btn-orange {
        color: #fff7ed; background: linear-gradient(135deg, #ea580c, var(--c2));
        box-shadow: 0 8px 20px rgba(249,115,22,0.28);
      }
      .btn-ghost {
        color: var(--muted); background: transparent; border: 2px solid #d1e7e4;
      }
      .btn-ghost:hover { border-color: var(--c1); color: var(--c1); }
      .btn:focus-visible {
        outline: 3px solid rgba(13,148,136,0.28);
        outline-offset: 3px;
      }

      /* ===== HERO ===== */
      .hero {
        padding: 80px 0 60px;
        background: linear-gradient(160deg, #f0fdfa 0%, #ecfdf5 30%, #fff7ed 70%, #fffbeb 100%);
        position: relative; overflow: hidden;
      }
      .hero::before {
        content: ''; position: absolute; top: -120px; right: -80px;
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(13,148,136,0.08), transparent 70%);
      }
      .hero::after {
        content: ''; position: absolute; bottom: -60px; left: -40px;
        width: 300px; height: 300px; border-radius: 50%;
        background: radial-gradient(circle, rgba(249,115,22,0.06), transparent 70%);
      }
      .hero-grid {
        display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); align-items: center; gap: 48px;
        position: relative; z-index: 1;
      }
      .badge {
        display: inline-flex; align-items: center; gap: 8px; border-radius: 999px;
        padding: 6px 16px; background: #fff; border: 1px solid #fed7aa;
        color: #9a3412; font-weight: 700; font-size: 0.88rem;
        box-shadow: var(--shadow-sm);
      }
      .badge .dot {
        width: 8px; height: 8px; border-radius: 50%; background: var(--c2);
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.5); }
      }
      .hero h1 {
        font-family: 'Baloo 2', cursive; font-size: clamp(2.2rem, 4.2vw, 3.8rem);
        line-height: 1.1; margin-top: 18px; color: var(--ink);
      }
      .hero h1 em {
        font-style: normal;
        background: linear-gradient(135deg, var(--c1), var(--c2));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-desc { font-size: 1.15rem; color: var(--muted); max-width: 52ch; margin-top: 16px; line-height: 1.7; }
      .hero-actions { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 12px; }

      .hero-visual {
        position: relative;
        animation: drift 10s ease-in-out infinite;
      }
      @keyframes drift {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
      .hero-img-wrap {
        border-radius: var(--radius-lg); overflow: hidden;
        box-shadow: var(--shadow-lg); position: relative;
      }
      .hero-img-wrap img {
        width: 100%; height: 340px; object-fit: cover; display: block;
      }
      .hero-img-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(13,148,136,0.15) 100%);
      }
      .hero-float-card {
        position: absolute; bottom: -20px; left: -16px;
        background: #fff; border-radius: 16px; padding: 14px 18px;
        box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 12px;
        animation: float 3s ease-in-out infinite;
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
      .hero-float-icon {
        width: 44px; height: 44px; border-radius: 12px; background: var(--c1-light);
        display: grid; place-items: center; font-size: 1.3rem;
      }
      .hero-float-text strong { display: block; font-size: 0.95rem; color: var(--ink); }
      .hero-float-text span { font-size: 0.8rem; color: var(--muted); }
      .hero-rating-card {
        position: absolute; top: -12px; right: -12px;
        background: #fff; border-radius: 16px; padding: 12px 16px;
        box-shadow: var(--shadow); text-align: center;
        animation: float 3s ease-in-out infinite 1s;
      }
      .hero-rating-card .stars { font-size: 1.1rem; }
      .hero-rating-card span { display: block; font-size: 0.78rem; color: var(--muted); font-weight: 700; }

      /* ===== SECTIONS ===== */
      section { padding: 72px 0; }
      .section-header { max-width: 640px; }
      .section-tag {
        display: inline-flex; align-items: center; gap: 6px;
        font-weight: 800; font-size: 0.82rem; text-transform: uppercase;
        letter-spacing: 1.2px; color: var(--c1); margin-bottom: 8px;
      }
      .section-tag::before {
        content: ''; width: 24px; height: 3px; border-radius: 999px;
        background: linear-gradient(90deg, var(--c1), var(--c2));
      }
      .section-title {
        font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem, 3vw, 2.6rem);
        line-height: 1.15; color: var(--ink);
      }
      .section-desc { color: var(--muted); margin-top: 10px; line-height: 1.7; max-width: 58ch; }

      /* ===== SERVICES ===== */
      #servicos { background: linear-gradient(180deg, var(--bg), #f0fdfa); }
      .services-grid {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; margin-top: 32px;
      }
      .service-card {
        background: var(--card); border-radius: var(--radius); padding: 28px 24px;
        box-shadow: var(--shadow-sm); border: 1px solid rgba(13,148,136,0.06);
        transition: all 0.35s ease; position: relative; overflow: hidden;
      }
      .service-card:hover {
        transform: translateY(-6px); box-shadow: var(--shadow-lg);
        border-color: rgba(13,148,136,0.12);
      }
      .service-card:nth-child(2n) { transform: translateY(4px); }
      .service-card:nth-child(2n):hover { transform: translateY(-4px); }
      .service-card::after {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--c1), var(--c2));
        opacity: 0; transition: opacity 0.35s;
      }
      .service-card:hover::after { opacity: 1; }
      .service-icon {
        width: 52px; height: 52px; border-radius: 16px; display: grid; place-items: center;
        font-size: 1.5rem; background: linear-gradient(135deg, var(--c1-light), #d1fae5);
      }
      .service-card h3 { margin-top: 16px; font-size: 1.15rem; font-weight: 800; }
      .service-card p { margin-top: 8px; color: var(--muted); line-height: 1.6; font-size: 0.92rem; }
      .service-price {
        margin-top: 16px; display: inline-flex; align-items: center; gap: 4px;
        color: var(--c1-dark); font-weight: 800; font-size: 1.05rem;
        padding: 4px 12px; border-radius: 999px; background: var(--c1-light);
      }

      /* ===== SIMULATOR ===== */
      #simulador { background: linear-gradient(180deg, #f0fdfa, #ecfdf5); }
      .simulator-layout {
        margin-top: 36px;
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.8fr);
        gap: 18px;
        align-items: start;
      }

      .stepper {
        display: flex; align-items: center; justify-content: center; gap: 0;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .step-indicator {
        display: flex; align-items: center; gap: 0;
      }
      .step-dot {
        width: 40px; height: 40px; border-radius: 50%; display: grid; place-items: center;
        font-weight: 800; font-size: 0.9rem; border: 3px solid #d1e7e4;
        background: #fff; color: var(--muted); transition: all 0.35s ease;
        position: relative; z-index: 2;
      }
      .step-dot.active {
        border-color: var(--c1); color: #fff;
        background: linear-gradient(135deg, var(--c1), #2dd4bf);
        box-shadow: 0 4px 14px rgba(13,148,136,0.3);
      }
      .step-dot.done {
        border-color: var(--c1); color: #fff;
        background: var(--c1);
      }
      .step-line {
        width: 42px; height: 3px; background: #d1e7e4; z-index: 1;
        transition: background 0.35s ease;
      }
      .step-line.active { background: var(--c1); }
      .step-label {
        display: none; font-size: 0.72rem; font-weight: 700; color: var(--muted);
        margin-top: 6px; text-align: center;
      }
      .step-dot.active + .step-label,
      .step-dot.done + .step-label { color: var(--c1); }

      .wizard {
        background: var(--card); border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg); overflow: hidden;
        border: 1px solid rgba(13,148,136,0.08);
        display: flex; flex-direction: column;
        min-height: 0;
        max-height: none;
      }
      .wizard-body {
        padding: 22px 22px 16px;
        position: relative;
        overflow: hidden;
        min-height: 0;
        flex: 1;
        min-width: 0;
      }
      .wizard-footer {
        padding: 14px 18px;
        border-top: 1px solid #deecea;
        background: #f9fefd;
      }
      .wizard-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .wizard-actions .btn { width: 100%; }
      .wizard-actions #nextBtn,
      .wizard-actions #sendBtn { grid-column: span 2; }
      .wizard-note {
        margin-top: 8px;
        font-size: 0.76rem;
        color: #5c797c;
      }

      .step-panel {
        display: none; animation: fadeSlide 0.4s ease;
      }
      .step-panel.active { display: block; }
      @keyframes fadeSlide {
        from { opacity: 0; transform: translateX(24px); }
        to { opacity: 1; transform: translateX(0); }
      }

      .step-panel h3 { font-family: 'Baloo 2', cursive; font-size: 1.4rem; margin-bottom: 6px; }
      .step-panel .step-desc { color: var(--muted); margin-bottom: 14px; line-height: 1.5; }

      .service-picker {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px;
      }
      .service-option {
        border: 2px solid #e5ecea; border-radius: 16px; padding: 12px 10px;
        cursor: pointer; transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
        position: relative; background: #fff;
      }
      .service-option:hover { border-color: var(--c1); background: var(--c1-light); }
      .service-option:hover { transform: translateY(-2px) scale(1.01); }
      .service-option.selected {
        border-color: var(--c1); background: var(--c1-light);
        box-shadow: 0 0 0 3px rgba(13,148,136,0.15);
      }
      .service-option .opt-check {
        position: absolute; top: 10px; right: 10px;
        width: 22px; height: 22px; border-radius: 50%; border: 2px solid #c4d8d4;
        display: grid; place-items: center; font-size: 0.7rem;
        transition: all 0.2s; color: transparent;
      }
      .service-option.selected .opt-check {
        background: var(--c1); border-color: var(--c1); color: #fff;
      }
      .service-option .opt-emoji { font-size: 1.2rem; margin-bottom: 4px; }
      .service-option .opt-name { font-weight: 800; font-size: 0.82rem; line-height: 1.25; }
      .service-option .opt-price { color: var(--c1-dark); font-weight: 700; font-size: 0.85rem; margin-top: 2px; }
      .service-help {
        margin-top: 12px;
        padding-bottom: 6px;
        color: #5c797c;
        font-size: 0.84rem;
        font-weight: 700;
        line-height: 1.45;
        min-height: 2.9em;
        display: block;
      }
      .service-help.error { color: #b91c1c; }

      .size-picker { display: flex; gap: 12px; flex-wrap: wrap; }
      .size-option {
        flex: 1; min-width: 120px; border: 2px solid #e5ecea; border-radius: 16px;
        padding: 16px 14px; text-align: center; cursor: pointer;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
        background: #fff;
      }
      .size-option:hover { border-color: var(--c1); }
      .size-option:hover { transform: translateY(-2px); }
      .size-option.selected {
        border-color: var(--c1); background: var(--c1-light);
        box-shadow: 0 0 0 3px rgba(13,148,136,0.15);
      }
      .size-option .sz-emoji { font-size: 1.8rem; margin-bottom: 4px; }
      .size-option .sz-name { font-weight: 800; }
      .size-option .sz-mult { font-size: 0.82rem; color: var(--muted); margin-top: 2px; }

      .extra-chips { display: flex; flex-wrap: wrap; gap: 10px; }
      .extra-chip {
        border: 2px solid #e5ecea; border-radius: 999px; padding: 9px 16px;
        cursor: pointer; display: flex; align-items: center; gap: 8px;
        font-weight: 700; font-size: 0.86rem; transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
        background: #fff; user-select: none;
      }
      .extra-chip:hover { border-color: var(--c2); background: var(--c2-light); }
      .extra-chip:hover { transform: translateY(-2px); }
      .extra-chip.selected {
        border-color: var(--c2); background: var(--c2-light); color: #9a3412;
        box-shadow: 0 0 0 3px rgba(249,115,22,0.12);
      }
      .extra-chip .chip-emoji { font-size: 1.1rem; }
      .extra-chip .chip-price { color: var(--c2); font-size: 0.82rem; }

      .field { margin-bottom: 16px; }
      .field label { display: block; font-weight: 700; margin-bottom: 6px; font-size: 0.92rem; }
      .field input {
        width: 100%; border: 2px solid #e5ecea; border-radius: 14px;
        padding: 13px 14px; font: inherit; font-size: 0.98rem;
        transition: border-color 0.2s;
      }
      .field input:focus { outline: none; border-color: var(--c1); }

      /* ===== SUMMARY PANEL ===== */
      .summary-panel {
        background: linear-gradient(135deg, var(--c1-dark), var(--c1));
        border-radius: var(--radius-lg); padding: 32px; color: #fff;
        margin-top: 18px; position: relative; overflow: hidden;
      }
      .summary-panel::before {
        content: ''; position: absolute; top: -60px; right: -60px;
        width: 200px; height: 200px; border-radius: 50%;
        background: rgba(255,255,255,0.05);
      }
      .summary-label { font-size: 0.85rem; opacity: 0.8; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
      .summary-price {
        font-family: 'Baloo 2', cursive; font-size: clamp(2.4rem, 5vw, 3.2rem);
        line-height: 1; margin: 8px 0 20px;
      }
      .summary-items { list-style: none; padding: 0; }
      .summary-items li {
        padding: 10px 0; border-top: 1px solid rgba(255,255,255,0.15);
        display: flex; justify-content: space-between; font-size: 0.92rem;
      }
      .summary-items li:last-child { border-bottom: 1px solid rgba(255,255,255,0.15); }
      .summary-items .item-label { opacity: 0.8; }
      .summary-items .item-value { font-weight: 800; }
      .summary-disclaimer { font-size: 0.78rem; opacity: 0.6; margin-top: 10px; line-height: 1.5; }

      .live-summary {
        background: #fff;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(13,148,136,0.08);
        box-shadow: var(--shadow);
        padding: 20px;
        position: sticky;
        top: 86px;
      }
      .live-summary .ls-tag {
        display: inline-flex;
        align-items: center;
        font-size: 0.72rem;
        font-weight: 800;
        color: #0f766e;
        background: #ecfdf5;
        border-radius: 999px;
        padding: 5px 10px;
      }
      .live-summary h4 {
        margin-top: 10px;
        font-size: 1.03rem;
        font-weight: 800;
      }
      .live-total {
        margin-top: 8px;
        font-family: 'Baloo 2', cursive;
        font-size: 2rem;
        line-height: 1;
        color: #0f766e;
      }
      .live-list {
        list-style: none;
        margin-top: 12px;
        padding: 0;
        border-top: 1px dashed #cfe4e1;
      }
      .live-list li {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        padding: 9px 0;
        border-bottom: 1px dashed #cfe4e1;
        font-size: 0.88rem;
      }
      .live-list li span { color: #4b6a74; }
      .live-list li strong { text-align: right; max-width: 60%; font-size: 0.86rem; }
      .live-tags {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
      }
      .live-tags .tag {
        border-radius: 999px;
        padding: 5px 9px;
        background: #e6fffb;
        color: #0f766e;
        font-size: 0.74rem;
        font-weight: 700;
      }
      .live-note {
        margin-top: 12px;
        color: #5b7379;
        font-size: 0.76rem;
        line-height: 1.45;
      }

      /* ===== TESTIMONIALS ===== */
      #avaliacoes { background: #fff; }
      .testimonials-shell {
        margin-top: 32px;
        position: relative;
      }
      .testimonials-controls {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 14px;
      }
      .testimonials-controls .btn {
        padding: 8px 12px;
        min-height: 38px;
        font-size: 0.84rem;
      }
      .testimonials {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: minmax(300px, 48%);
        gap: 20px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        padding-bottom: 8px;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
      }
      .testimonials::-webkit-scrollbar { display: none; }
      .carousel-dots {
        display: flex; justify-content: center; gap: 8px;
        margin-top: 14px; padding: 0;
      }
      .carousel-dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: rgba(13,148,136,0.2); border: none; padding: 0;
        cursor: pointer; transition: all 0.3s;
      }
      .carousel-dot.active { background: var(--primary); transform: scale(1.25); }
      .carousel-dot:hover { background: rgba(13,148,136,0.5); }
      .carousel-dot:focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; }
      .quote-card {
        background: var(--bg); border-radius: var(--radius); padding: 24px;
        border: 1px solid rgba(13,148,136,0.08); transition: all 0.3s;
        scroll-snap-align: start;
      }
      .quote-card:hover { box-shadow: var(--shadow); transform: translateY(-4px); }
      .quote-stars { margin-bottom: 12px; font-size: 1rem; }
      .quote-card blockquote { color: #2f555a; line-height: 1.7; font-style: italic; }
      .quote-author {
        margin-top: 16px; display: flex; align-items: center; gap: 10px;
      }
      .quote-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: linear-gradient(135deg, var(--c1-light), #d1fae5);
        display: grid; place-items: center; font-size: 1.1rem;
      }
      .quote-author strong { display: block; font-size: 0.88rem; }
      .quote-author span { font-size: 0.78rem; color: var(--muted); }

      /* ===== INSTAGRAM ===== */
      #instagram { background: linear-gradient(180deg, #fff, var(--c2-light)); }
      .ig-layout { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr); gap: 32px; margin-top: 32px; align-items: start; }
      .ig-info {
        background: var(--card); border-radius: var(--radius-lg); padding: 32px;
        box-shadow: var(--shadow); border: 1px solid rgba(249,115,22,0.08);
        min-width: 0;
      }
      .ig-handle { font-family: 'Baloo 2', cursive; font-size: 1.3rem; color: var(--ink); margin-bottom: 8px; }
      .ig-handle a { color: var(--c2); text-decoration: none; }
      .ig-handle a:hover { text-decoration: underline; }
      .ig-desc { color: var(--muted); line-height: 1.7; margin-bottom: 18px; }
      .ig-stats { display: flex; gap: 20px; }
      .ig-stat { text-align: center; }
      .ig-stat strong { display: block; font-size: 1.2rem; color: var(--ink); }
      .ig-stat span { font-size: 0.78rem; color: var(--muted); }
      .ig-cta-row {
        margin-top: 18px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .ig-embed-wrap {
        background: var(--card); border-radius: var(--radius-lg);
        box-shadow: var(--shadow); overflow: hidden; min-height: 400px;
        min-width: 0;
      }
      .ig-embed-wrap iframe { width: 100%; height: 560px; border: 0; display: block; }

      .map-card {
        margin-top: 20px;
        background: var(--card);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        overflow: hidden;
        border: 1px solid rgba(13,148,136,0.08);
      }
      .map-card-head {
        padding: 18px 20px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
      }
      .map-card-head h3 {
        font-family: 'Baloo 2', cursive;
        font-size: 1.15rem;
      }
      .map-card-head p {
        color: var(--muted);
        font-size: 0.92rem;
        margin-top: 4px;
      }
      .map-card-actions { display: flex; gap: 10px; flex-wrap: wrap; }
      .map-embed { width: 100%; aspect-ratio: 16 / 6; min-height: 280px; border: 0; display: block; }

      .tour-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
        gap: 20px;
        margin-top: 28px;
        align-items: start;
      }
      .tour-card {
        background: var(--card);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow);
        border: 1px solid rgba(13,148,136,0.08);
        min-width: 0;
      }
      .tour-card h3 {
        font-family: 'Baloo 2', cursive;
        font-size: 1.2rem;
        margin-bottom: 8px;
      }
      .tour-card p {
        color: var(--muted);
        line-height: 1.7;
      }
      .tour-badges {
        margin-top: 16px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .tour-badges span {
        border-radius: 999px;
        padding: 6px 10px;
        background: #ecfdf5;
        color: #0f766e;
        font-size: 0.8rem;
        font-weight: 800;
      }
      .tour-embed {
        background: var(--card);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow);
        border: 1px solid rgba(13,148,136,0.08);
      }
      .tour-embed iframe { width: 100%; min-height: 420px; border: 0; display: block; }

      /* ===== CONTACT ===== */
      #contato { background: linear-gradient(180deg, var(--c2-light), var(--bg)); }
      .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
      .contact-card {
        background: var(--card); border-radius: var(--radius-lg); padding: 28px;
        box-shadow: var(--shadow); border: 1px solid rgba(13,148,136,0.06);
      }
      .contact-card h3 {
        font-family: 'Baloo 2', cursive; font-size: 1.2rem;
        display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
      }
      .contact-card h3 .ci { font-size: 1.3rem; }
      .contact-card p { color: var(--muted); line-height: 1.8; }
      .contact-card a { color: var(--c1); font-weight: 700; text-decoration: none; }
      .contact-card a:hover { text-decoration: underline; }
      .contact-phone { font-weight: 800; color: var(--ink); }
      .contact-actions {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }
      .contact-actions .btn { width: 100%; min-height: 50px; text-align: center; }
      .contact-actions .btn-primary { color: #ffffff; }
      .contact-actions .btn-orange { color: #fff8ef; }

      /* ===== FOOTER ===== */
      .site-footer {
        border-top: 1px solid rgba(13,148,136,0.1); padding: 28px 0;
        color: var(--muted); font-size: 0.88rem;
      }

      /* ===== FLOAT WHATSAPP ===== */
      .float-wa {
        position: fixed; bottom: 24px; right: 24px; z-index: 60;
        width: 60px; height: 60px; border-radius: 50%;
        background: #25d366; color: #fff; display: grid; place-items: center;
        box-shadow: 0 6px 20px rgba(37,211,102,0.4);
        text-decoration: none; font-size: 1.7rem;
        transition: all 0.3s ease;
      }
      .float-wa:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,0.5); }

      /* ===== REVEAL ===== */
      .reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
      .reveal.visible { opacity: 1; transform: translateY(0); animation: revealPop 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
      @keyframes revealPop {
        0% { filter: blur(4px); transform: translateY(24px) scale(0.98); }
        100% { filter: blur(0); transform: translateY(0) scale(1); }
      }
      .hero h1, .service-card, .quote-card, .contact-card, .map-card {
        animation: softGlow 8s ease-in-out infinite;
      }
      @keyframes softGlow {
        0%, 100% { box-shadow: var(--shadow); }
        50% { box-shadow: var(--shadow-lg); }
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 980px) {
        .hero-grid, .ig-layout, .contact-grid { grid-template-columns: 1fr; }
        .tour-layout { grid-template-columns: 1fr; }
        .services-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .menu a:not(.btn) { display: none; }
        .hero-visual { order: -1; }
        .hero-float-card, .hero-rating-card { display: none; }
        .simulator-layout { grid-template-columns: 1fr; }
        .wizard {
          min-height: min(74vh, 700px);
          max-height: min(74vh, 700px);
        }
        .live-summary {
          position: static;
          top: auto;
        }
        .service-picker { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .testimonials { grid-auto-columns: minmax(300px, 72%); }
      }
      @media (max-width: 640px) {
        .hero { padding: 48px 0 36px; }
        section { padding: 48px 0; }
        .services-grid { grid-template-columns: 1fr; }
        .service-picker { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .size-picker { flex-direction: column; }
        .wizard {
          min-height: min(82vh, 800px);
          max-height: min(82vh, 800px);
        }
        .wizard-body { padding: 18px 14px 14px; }
        .wizard-footer { padding: 10px; }
        .wizard-actions {
          grid-template-columns: 1fr;
        }
        .wizard-actions #nextBtn,
        .wizard-actions #sendBtn {
          grid-column: span 1;
        }
        .step-line { width: 32px; }
        .step-dot { width: 36px; height: 36px; font-size: 0.82rem; }
        .live-list li strong { max-width: 54%; }
        .contact-actions { grid-template-columns: 1fr; }
        .map-embed { aspect-ratio: 4 / 3; min-height: 240px; }
        .tour-embed iframe { min-height: 320px; }
        .ig-embed-wrap iframe { height: 560px; }
        .ig-cta-row { align-items: stretch; }
        .testimonials { grid-auto-columns: 86%; gap: 14px; }
        .testimonials-controls { margin-bottom: 10px; }
        .testimonials-controls .btn { min-height: 34px; font-size: 0.78rem; padding: 7px 10px; }
        .service-help { min-height: 3.6em; }
      }
      @media (max-width: 420px) {
        .service-picker { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <header class="site-header" id="siteHeader">
      <div class="container">
        <a href="#inicio" class="brand" aria-label="Ir para o início">
          <span class="logo-icon">
            <img src="https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_588,h_472,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png" alt="Cão de Estrelas" />
          </span>
          <span class="brand-text">Cão de <span>Estrelas</span></span>
        </a>
        <nav class="menu" aria-label="Navegação principal">
          <a href="#servicos">Serviços</a>
          <a href="#simulador">Agendar</a>
          <a href="#avaliacoes">Avaliações</a>
          <a href="#instagram">Instagram</a>
          <a href="#contato">Contato</a>
          <a class="btn btn-primary" href="#simulador">Agendar agora</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- HERO -->
      <section id="inicio" class="hero">
        <div class="container hero-grid">
          <div class="reveal">
            <span class="badge"><span class="dot"></span> Atendimento com amor e profissionalismo</span>
            <h1>Seu pet <em>brilhando</em> como estrela em cada cuidado.</h1>
            <p class="hero-desc">
              Banho, tosa, hidratação, consulta veterinária e muito mais para o seu melhor amigo ficar lindo, saudável e feliz.
            </p>
            <div class="hero-actions" style="margin-top:14px; gap:8px;">
              <span class="badge" style="padding:5px 12px; font-size:0.8rem;">Especialistas em Schnauzer</span>
              <span class="badge" style="padding:5px 12px; font-size:0.8rem;">Spitz Alemão</span>
              <span class="badge" style="padding:5px 12px; font-size:0.8rem;">Golden Retriever</span>
            </div>
            <div class="hero-actions">
              <a class="btn btn-primary" href="#simulador">Fazer orçamento</a>
              <a class="btn btn-secondary" href="#contato">Ver horários</a>
            </div>
          </div>
          <div class="hero-visual reveal">
            <div class="hero-img-wrap">
              <img src="https://images.unsplash.com/photo-1601758228041-f3b2795255f1?auto=format&fit=crop&w=1200&q=80" alt="Cachorro feliz após banho no pet shop" loading="lazy" />
              <div class="hero-img-overlay"></div>
            </div>
            <div class="hero-float-card">
              <div class="hero-float-icon">✨</div>
              <div class="hero-float-text">
                <strong>+2.500 pets atendidos</strong>
                <span>com carinho e segurança</span>
              </div>
            </div>
            <div class="hero-rating-card">
              <div class="stars">⭐⭐⭐⭐⭐</div>
              <span>4.9/5 avaliações</span>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICES -->
      <section id="servicos" class="container reveal">
        <div class="section-header">
          <div class="section-tag">Serviços</div>
          <h2 class="section-title">Nossos serviços mais amados</h2>
          <p class="section-desc">Cuidamos de cães e gatos com carinho em todas as etapas: estética, saúde e bem-estar.</p>
        </div>
        <div class="services-grid">
          {services.map((s) => (
            <article class="service-card">
              <div class="service-icon">{s.emoji}</div>
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
              <div class="service-price">A partir de R$ {s.price}</div>
            </article>
          ))}
        </div>
      </section>

      <!-- SIMULATOR -->
      <section id="simulador" class="reveal">
        <div class="container">
          <div class="section-header">
            <div class="section-tag">Agendamento</div>
            <h2 class="section-title">Orçamento rápido em 6 passos</h2>
            <p class="section-desc">Monte seu pacote em segundos e envie diretamente para o WhatsApp do pet shop.</p>
          </div>

          <div class="simulator-layout">
            <div class="wizard" id="wizard">
              <!-- STEPPER -->
              <div class="wizard-body">
                <div class="stepper" id="stepper">
                  <div class="step-indicator">
                    <div class="step-dot active" data-step="0">1</div>
                  </div>
                  <div class="step-line" data-line="0"></div>
                  <div class="step-indicator">
                    <div class="step-dot" data-step="1">2</div>
                  </div>
                  <div class="step-line" data-line="1"></div>
                  <div class="step-indicator">
                    <div class="step-dot" data-step="2">3</div>
                  </div>
                  <div class="step-line" data-line="2"></div>
                  <div class="step-indicator">
                    <div class="step-dot" data-step="3">4</div>
                  </div>
                  <div class="step-line" data-line="3"></div>
                  <div class="step-indicator">
                    <div class="step-dot" data-step="4">5</div>
                  </div>
                  <div class="step-line" data-line="4"></div>
                  <div class="step-indicator">
                    <div class="step-dot" data-step="5">6</div>
                  </div>
                </div>

                <!-- STEP 1: Service -->
                <div class="step-panel active" data-panel="0">
                  <h3>Escolha os serviços</h3>
                  <p class="step-desc">Você pode selecionar um ou varios servicos para somar no mesmo orçamento.</p>
                  <div class="service-picker" id="servicePicker">
                    {services.map((s) => (
                      <div class="service-option" data-service={s.id} data-price={s.price} tabindex="0" role="button" aria-pressed="false">
                        <div class="opt-check">✓</div>
                        <div class="opt-emoji">{s.emoji}</div>
                        <div class="opt-name">{s.name}</div>
                        <div class="opt-price">R$ {s.price}+</div>
                      </div>
                    ))}
                  </div>
                  <p class="service-help" id="serviceHint">Selecione pelo menos 1 serviço para continuar.</p>
                </div>

                <!-- STEP 2: Size -->
                <div class="step-panel" data-panel="1">
                  <h3>Porte do pet</h3>
                  <p class="step-desc">Isso ajusta o valor e mantém o fluxo leve.</p>
                  <div class="size-picker" id="sizePicker">
                    <div class="size-option selected" data-size="pequeno" data-mult="1" tabindex="0" role="button" aria-pressed="true">
                      <div class="sz-emoji">🐕</div>
                      <div class="sz-name">Pequeno</div>
                      <div class="sz-mult">valor base</div>
                    </div>
                    <div class="size-option" data-size="medio" data-mult="1.25" tabindex="0" role="button" aria-pressed="false">
                      <div class="sz-emoji">🐕‍🦺</div>
                      <div class="sz-name">Médio</div>
                      <div class="sz-mult">+25%</div>
                    </div>
                    <div class="size-option" data-size="grande" data-mult="1.55" tabindex="0" role="button" aria-pressed="false">
                      <div class="sz-emoji">🦮</div>
                      <div class="sz-name">Grande</div>
                      <div class="sz-mult">+55%</div>
                    </div>
                  </div>
                </div>

                <!-- STEP 3: Extras -->
                <div class="step-panel" data-panel="2">
                  <h3>Serviços extras</h3>
                  <p class="step-desc">Escolha só o que fizer sentido para o seu pet.</p>
                  <div class="extra-chips" id="extraChips">
                    {extras.map((e) => (
                      <div class="extra-chip" data-extra-id={e.id} data-extra-price={e.price} tabindex="0" role="button" aria-pressed="false">
                        <span class="chip-emoji">{e.emoji}</span>
                        <span>{e.name}</span>
                        <span class="chip-price">+R$ {e.price}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- STEP 4: Info -->
                <div class="step-panel" data-panel="3">
                  <h3>Seus dados</h3>
                  <p class="step-desc">Precisamos saber quem é você e quem é o seu pet.</p>

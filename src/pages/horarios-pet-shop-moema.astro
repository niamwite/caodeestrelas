          <div class="hero-visual">
            <div class="hero-img-wrap">
              <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1200&q=80" alt="Horário do pet shop em Moema" loading="lazy" />

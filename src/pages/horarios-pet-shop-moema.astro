            </div>
            <div class="dia-card">
              <h3>Quarta-feira</h3>
              <div class="horario">8h — 18h</div>
              <p>Banho, tosa e veterinário</p>
            </div>
            <div class="dia-card">
              <h3>Quinta-feira</h3>

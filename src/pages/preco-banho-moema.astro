---
const siteUrl = 'https://www.caodeestrelas.com.br';
const pageUrl = `${siteUrl}/preco-banho-moema`;
const ogImage = 'https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_1200,h_960,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'PetStore',
  name: 'Cão de Estrelas Pet Shop',
  url: siteUrl,
  image: ogImage,
  telephone: '+5511942891718',
  priceRange: '$$',
  address: { '@type': 'PostalAddress', streetAddress: 'Rua Gaivota, 903', addressLocality: 'Moema', addressRegion: 'SP', postalCode: '04522-031', addressCountry: 'BR' },
  sameAs: ['https://www.instagram.com/caodeestrelas/'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '249' }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Qual o preço de banho em Moema?', acceptedAnswer: { '@type': 'Answer', text: 'No Cão de Estrelas, os preços de banho em Moema começam em R$ 45 para portes pequenos. Médio R$ 55 e grande R$ 70. Valores incluem shampoo, secagem, perfumação, corte de unhas e limpeza de ouvidos.' } },
    { '@type': 'Question', name: 'Banho para cachorro grande custa quanto em Moema?', acceptedAnswer: { '@type': 'Answer', text: 'O banho para cachorro grande no Cão de Estrelas custa R$ 70. Este valor inclui shampoo específico para pelagens densas, secagem profissional, perfumação, corte de unhas e limpeza de ouvidos.' } },
    { '@type': 'Question', name: 'O que inclui no banho do pet shop?', acceptedAnswer: { '@type': 'Answer', text: 'O banho inclui: shampoo específico para o tipo de pelo do seu pet, secagem profissional com temperatura controlada, perfumação suave, corte de unhas, limpeza de ouvidos e avaliação gratuita da pele e pelagem.' } }
  ]
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Preço de Banho em Moema 2025 | Cão de Estrelas — Tabela de Preços</title>
    <meta name="description" content="Preço de banho em Moema 2025. Tabela completa: banho pequeno, médio e grande. Cão de Estrelas — qualidade com o melhor custo-benefício." />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0d9488" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Cão de Estrelas Pet Shop" />
    <meta property="og:title" content="Preço de Banho em Moema 2025 | Cão de Estrelas" />
    <meta property="og:description" content="Preço de banho em Moema 2025. Tabela completa: banho pequeno, médio e grande. Cão de Estrelas — qualidade com o melhor custo-benefício." />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      :root { --c1: #0d9488; --c1-light: #ccfbf1; --c1-dark: #065f52; --c2: #f97316; --c2-light: #fff7ed; --ink: #1a2e35; --muted: #4b6a74; --card: #ffffff; --bg: #f8fffe; --radius: 20px; --radius-lg: 28px; --shadow-sm: 0 2px 8px rgba(13,148,136,0.06); --shadow: 0 8px 30px rgba(13,148,136,0.10); --shadow-lg: 0 20px 50px rgba(13,148,136,0.14); }
      *, *::before, *::after { box-sizing: border-box; margin: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: 'Nunito', sans-serif; color: var(--ink); background: var(--bg); -webkit-font-smoothing: antialiased; }
      .container { width: min(1200px, calc(100% - 32px)); margin: 0 auto; }
      .btn { border: 0; border-radius: 999px; padding: 12px 24px; font-size: 0.95rem; font-weight: 800; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.25s ease; font-family: inherit; }
      .btn:hover { transform: translateY(-2px); }
      .btn-primary { color: #fff; background: linear-gradient(135deg, var(--c1), #2dd4bf); box-shadow: 0 8px 20px rgba(13,148,136,0.25); }
      .btn-secondary { color: #064e4b; background: #d9fffb; border: 2px solid rgba(13,148,136,0.12); box-shadow: 0 8px 16px rgba(13,148,136,0.08); }
      .site-header { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(16px); background: rgba(248,255,254,0.82); border-bottom: 1px solid rgba(13,148,136,0.08); }
      .site-header .container { display: flex; align-items: center; justify-content: space-between; min-height: 68px; gap: 12px; }
      .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ink); }
      .logo-icon { width: 44px; height: 44px; border-radius: 14px; display: grid; place-items: center; overflow: hidden; background: #fff; box-shadow: 0 6px 16px rgba(13,148,136,0.18); border: 1px solid rgba(13,148,136,0.12); }
      .logo-icon img { width: 100%; height: 100%; object-fit: cover; }
      .brand-text { font-family: 'Baloo 2', cursive; font-size: 1.35rem; }
      .brand-text span { color: var(--c1); }
      .menu { display: flex; align-items: center; gap: 6px; }
      .menu a { text-decoration: none; color: var(--muted); font-weight: 700; font-size: 0.9rem; padding: 8px 14px; border-radius: 10px; transition: all 0.2s; }
      .menu a:hover { color: var(--c1); background: var(--c1-light); }
      .hero { padding: 80px 0 60px; background: linear-gradient(160deg, #f0fdfa 0%, #ecfdf5 30%, #fff7ed 70%, #fffbeb 100%); }
      .hero-grid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); align-items: center; gap: 48px; }
      .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 6px 16px; background: #fff; border: 1px solid #fed7aa; color: #9a3412; font-weight: 700; font-size: 0.88rem; box-shadow: var(--shadow-sm); }
      .hero h1 { font-family: 'Baloo 2', cursive; font-size: clamp(2.2rem, 4.2vw, 3.8rem); line-height: 1.1; margin-top: 18px; }
      .hero h1 em { font-style: normal; background: linear-gradient(135deg, var(--c1), var(--c2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .hero-desc { font-size: 1.15rem; color: var(--muted); max-width: 52ch; margin-top: 16px; line-height: 1.7; }
      .hero-actions { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 12px; }
      .hero-visual { position: relative; }
      .hero-img-wrap { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg); }
      .hero-img-wrap img { width: 100%; height: 340px; object-fit: cover; display: block; }
      section { padding: 72px 0; }
      .section-header { max-width: 640px; }
      .section-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 800; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--c1); margin-bottom: 8px; }
      .section-tag::before { content: ''; width: 24px; height: 3px; border-radius: 999px; background: linear-gradient(90deg, var(--c1), var(--c2)); }
      .section-title { font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem, 3vw, 2.6rem); line-height: 1.15; }
      .section-desc { color: var(--muted); margin-top: 10px; line-height: 1.7; max-width: 58ch; }
      .pricing-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; margin-top: 32px; }
      .pricing-card { background: var(--card); border-radius: var(--radius-lg); padding: 32px; box-shadow: var(--shadow); border: 2px solid rgba(13,148,136,0.08); text-align: center; position: relative; }
      .pricing-card.popular { border-color: var(--c1); transform: scale(1.03); }
      .pricing-card.popular::before { content: 'Mais pedido'; position: absolute; top: -1px; left: 50%; transform: translateX(-50%); background: var(--c1); color: #fff; font-size: 0.72rem; font-weight: 800; padding: 6px 20px; border-radius: 0 0 12px 12px; }
      .pricing-card .size-icon { font-size: 3rem; margin-bottom: 12px; }
      .pricing-card h3 { font-family: 'Baloo 2', cursive; font-size: 1.4rem; }
      .pricing-card .price { font-size: 2.5rem; font-weight: 800; color: var(--c1-dark); margin: 16px 0; }
      .pricing-card .price span { font-size: 1rem; color: var(--muted); font-weight: 600; }
      .pricing-card .price-note { font-size: 0.85rem; color: var(--muted); margin-bottom: 20px; }
      .pricing-card ul { list-style: none; padding: 0; text-align: left; }
      .pricing-card ul li { padding: 10px 0; border-bottom: 1px dashed #e5ecea; font-size: 0.95rem; display: flex; align-items: center; gap: 10px; }
      .pricing-card ul li:last-child { border-bottom: none; }
      .pricing-card ul li::before { content: '✅'; font-size: 0.85rem; }
      #inclui { background: #fff; }
      .inclui-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; margin-top: 32px; }
      .inclui-card { background: var(--bg); border-radius: var(--radius); padding: 24px; border: 1px solid rgba(13,148,136,0.06); display: flex; gap: 16px; align-items: start; }
      .inclui-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--c1-light); display: grid; place-items: center; font-size: 1.3rem; flex-shrink: 0; }
      .inclui-card h3 { font-size: 1rem; font-weight: 800; }
      .inclui-card p { margin-top: 6px; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
      #faq { background: linear-gradient(180deg, var(--bg), #f0fdfa); }
      .faq-list { max-width: 720px; margin: 32px auto 0; }
      .faq-item { background: var(--card); border-radius: var(--radius); padding: 24px; margin-bottom: 16px; box-shadow: var(--shadow-sm); border: 1px solid rgba(13,148,136,0.06); }
      .faq-item h3 { font-size: 1.05rem; font-weight: 800; margin-bottom: 8px; }
      .faq-item p { color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
      #cta { background: linear-gradient(160deg, #f0fdfa, #ecfdf5); text-align: center; }
      .cta-content { max-width: 600px; margin: 0 auto; }
      .cta-content h2 { font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem, 3vw, 2.4rem); }
      .cta-content p { margin-top: 12px; color: var(--muted); font-size: 1.1rem; }
      .cta-actions { margin-top: 24px; display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
      .site-footer { border-top: 1px solid rgba(13,148,136,0.1); padding: 28px 0; color: var(--muted); font-size: 0.88rem; text-align: center; }
      .float-wa { position: fixed; bottom: 24px; right: 24px; z-index: 60; width: 60px; height: 60px; border-radius: 50%; background: #25d366; color: #fff; display: grid; place-items: center; box-shadow: 0 6px 20px rgba(37,211,102,0.4); text-decoration: none; font-size: 1.7rem; transition: all 0.3s ease; }
      .float-wa:hover { transform: scale(1.1); }
      @media (max-width: 980px) { .hero-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: 1fr; } .inclui-grid { grid-template-columns: 1fr; } .menu a:not(.btn) { display: none; } .hero-visual { order: -1; } .pricing-card.popular { transform: none; } }
      @media (max-width: 640px) { .hero { padding: 48px 0 36px; } section { padding: 48px 0; } }
    </style>
  </head>
  <body>
    <header class="site-header">

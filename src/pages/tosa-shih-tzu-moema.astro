---
const siteUrl = 'https://www.caodeestrelas.com.br';
const pageUrl = `${siteUrl}/tosa-shih-tzu-moema`;
const ogImage = 'https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_1200,h_960,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'PetStore',
  name: 'Cão de Estrelas Pet Shop',
  url: siteUrl,
  image: ogImage,
  telephone: '+5511942891718',
  priceRange: '$$',
  address: { '@type': 'PostalAddress', streetAddress: 'Rua Gaivota, 903', addressLocality: 'Moema', addressRegion: 'SP', postalCode: '04522-031', addressCountry: 'BR' },
  sameAs: ['https://www.instagram.com/caodeestrelas/'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '249' }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Qual a melhor tosa para Shih Tzu?', acceptedAnswer: { '@type': 'Answer', text: 'Para o dia a dia, a tosa baby é a mais prática: pelo curto no corpo e rosto arredondado. Para quem quer manter o glamour, a tosa filé mantém os pelos longos com visual elegante. Ambas são oferecidas no Cão de Estrelas.' } },
    { '@type': 'Question', name: 'Shih Tzu precisa de tosa frequente?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. O Shih Tzu tem pelagem que cresce continuamente e propensity a formar nós. Recomendamos tosa a cada 30 a 45 dias para manter o pelo gerenciado e evitar problemas de pele. Entre as sessões, escovação diária é essencial.' } },
    { '@type': 'Question', name: 'Como cuidar do pelo longo do Shih Tzu?', acceptedAnswer: { '@type': 'Answer', text: 'O pelo longo do Shih Tzu requer escovação diária para evitar nós, principalmente ao redor das orelhas e na região peitoral. O uso de condicionador spray e pentear diariamente são hábitos importantes que ensinamos aos tutores.' } }
  ]
};

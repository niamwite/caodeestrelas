      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Cão de Estrelas Pet Shop — Rua Gaivota, 903 — Moema, São Paulo</p>
        <p style="margin-top:8px;"><a href="tel:+5511942891718" style="color:var(--c1);">(11) 94289-1718</a></p>
      </div>
    </footer>

    <a class="float-wa" href="https://wa.me/5511942891718?text=Olá! Gostaria de informações sobre creche pet em Moema" aria-label="WhatsApp">💬</a>
  </body>
</html>

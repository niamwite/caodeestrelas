      #faq { background: linear-gradient(180deg, var(--bg), #f0fdfa); }
      .faq-list { max-width: 720px; margin: 32px auto 0; }
      .faq-item { background: var(--card); border-radius: var(--radius); padding: 24px; margin-bottom: 16px; box-shadow: var(--shadow-sm); border: 1px solid rgba(13,148,136,0.06); }

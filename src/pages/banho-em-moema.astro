---
const siteUrl = 'https://www.caodeestrelas.com.br';
const pageUrl = `${siteUrl}/banho-em-moema`;
const ogImage = 'https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_1200,h_960,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'PetStore',
  name: 'Cão de Estrelas Pet Shop',
  url: siteUrl,
  image: ogImage,
  telephone: '+5511942891718',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rua Gaivota, 903',
    addressLocality: 'Moema',
    addressRegion: 'SP',
    postalCode: '04522-031',
    addressCountry: 'BR'
  },
  sameAs: ['https://www.instagram.com/caodeestrelas/'],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '249'
  }
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Banho em Moema | Pet Shop Cão de Estrelas - Serviços de Banho para Cães</title>
    <meta name="description" content="Banho em Moema para seu cão. Pet shop Cão de Estrelas oferece banho completo com secagem cuidadosa e finalização cheirosa. Agende pelo WhatsApp." />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0d9488" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Cão de Estrelas Pet Shop" />
    <meta property="og:title" content="Banho em Moema | Pet Shop Cão de Estrelas" />
    <meta property="og:description" content="Banho completo para seu cão em Moema. Secagem cuidadosa e finalização cheirosa." />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      :root {
        --c1: #0d9488;
        --c1-light: #ccfbf1;
        --c1-dark: #065f52;
        --c2: #f97316;
        --c2-light: #fff7ed;
        --c3: #fbbf24;
        --ink: #1a2e35;
        --muted: #4b6a74;
        --card: #ffffff;
        --bg: #f8fffe;
        --radius: 20px;
        --radius-lg: 28px;
        --shadow-sm: 0 2px 8px rgba(13,148,136,0.06);
        --shadow: 0 8px 30px rgba(13,148,136,0.10);
        --shadow-lg: 0 20px 50px rgba(13,148,136,0.14);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: 'Nunito', sans-serif; color: var(--ink); background: var(--bg); -webkit-font-smoothing: antialiased; }
      .container { width: min(1200px, calc(100% - 32px)); margin: 0 auto; }
      .btn { border: 0; border-radius: 999px; padding: 12px 24px; font-size: 0.95rem; font-weight: 800; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.25s ease; font-family: inherit; }
      .btn:hover { transform: translateY(-2px); }
      .btn-primary { color: #fff; background: linear-gradient(135deg, var(--c1), #2dd4bf); box-shadow: 0 8px 20px rgba(13,148,136,0.25); }
      .btn-orange { color: #fff7ed; background: linear-gradient(135deg, #ea580c, var(--c2)); box-shadow: 0 8px 20px rgba(249,115,22,0.28); }
      .btn-secondary { color: #064e4b; background: #d9fffb; border: 2px solid rgba(13,148,136,0.12); box-shadow: 0 8px 16px rgba(13,148,136,0.08); }

      .site-header { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(16px); background: rgba(248,255,254,0.82); border-bottom: 1px solid rgba(13,148,136,0.08); }
      .site-header .container { display: flex; align-items: center; justify-content: space-between; min-height: 68px; gap: 12px; }
      .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ink); }
      .logo-icon { width: 44px; height: 44px; border-radius: 14px; display: grid; place-items: center; overflow: hidden; background: #fff; box-shadow: 0 6px 16px rgba(13,148,136,0.18); border: 1px solid rgba(13,148,136,0.12); }
      .logo-icon img { width: 100%; height: 100%; object-fit: cover; }
      .brand-text { font-family: 'Baloo 2', cursive; font-size: 1.35rem; }
      .brand-text span { color: var(--c1); }
      .menu { display: flex; align-items: center; gap: 6px; }
      .menu a { text-decoration: none; color: var(--muted); font-weight: 700; font-size: 0.9rem; padding: 8px 14px; border-radius: 10px; transition: all 0.2s; }
      .menu a:hover { color: var(--c1); background: var(--c1-light); }

      .hero { padding: 80px 0 60px; background: linear-gradient(160deg, #f0fdfa 0%, #ecfdf5 30%, #fff7ed 70%, #fffbeb 100%); }
      .hero-grid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); align-items: center; gap: 48px; }
      .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 6px 16px; background: #fff; border: 1px solid #fed7aa; color: #9a3412; font-weight: 700; font-size: 0.88rem; box-shadow: var(--shadow-sm); }
      .hero h1 { font-family: 'Baloo 2', cursive; font-size: clamp(2.2rem, 4.2vw, 3.8rem); line-height: 1.1; margin-top: 18px; }
      .hero h1 em { font-style: normal; background: linear-gradient(135deg, var(--c1), var(--c2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .hero-desc { font-size: 1.15rem; color: var(--muted); max-width: 52ch; margin-top: 16px; line-height: 1.7; }
      .hero-actions { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 12px; }
      .hero-visual { position: relative; animation: drift 10s ease-in-out infinite; }
      @keyframes drift { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
      .hero-img-wrap { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg); }
      .hero-img-wrap img { width: 100%; height: 340px; object-fit: cover; display: block; }
      .hero-img-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(13,148,136,0.15) 100%); }

      section { padding: 72px 0; }
      .section-header { max-width: 640px; }
      .section-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 800; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--c1); margin-bottom: 8px; }
      .section-tag::before { content: ''; width: 24px; height: 3px; border-radius: 999px; background: linear-gradient(90deg, var(--c1), var(--c2)); }
      .section-title { font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem, 3vw, 2.6rem); line-height: 1.15; color: var(--ink); }
      .section-desc { color: var(--muted); margin-top: 10px; line-height: 1.7; max-width: 58ch; }

      #servicos { background: linear-gradient(180deg, var(--bg), #f0fdfa); }
      .services-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; margin-top: 32px; }
      .service-card { background: var(--card); border-radius: var(--radius); padding: 28px 24px; box-shadow: var(--shadow-sm); border: 1px solid rgba(13,148,136,0.06); transition: all 0.35s ease; }
      .service-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: rgba(13,148,136,0.12); }
      .service-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--c1), var(--c2)); opacity: 0; transition: opacity 0.35s; }
      .service-card:hover::after { opacity: 1; }
      .service-icon { width: 52px; height: 52px; border-radius: 16px; display: grid; place-items: center; font-size: 1.5rem; background: linear-gradient(135deg, var(--c1-light), #d1fae5); }
      .service-card h3 { margin-top: 16px; font-size: 1.15rem; font-weight: 800; }
      .service-card p { margin-top: 8px; color: var(--muted); line-height: 1.6; font-size: 0.92rem; }
      .service-price { margin-top: 16px; display: inline-flex; align-items: center; gap: 4px; color: var(--c1-dark); font-weight: 800; font-size: 1.05rem; padding: 4px 12px; border-radius: 999px; background: var(--c1-light); }

      #beneficios { background: #fff; }
      .benefits-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; margin-top: 32px; }
      .benefit-card { background: var(--bg); border-radius: var(--radius); padding: 24px; border: 1px solid rgba(13,148,136,0.06); display: flex; gap: 16px; align-items: start; }
      .benefit-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--c1-light); display: grid; place-items: center; font-size: 1.3rem; flex-shrink: 0; }
      .benefit-card h3 { font-size: 1rem; font-weight: 800; }
      .benefit-card p { margin-top: 6px; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }

      #cta { background: linear-gradient(160deg, #f0fdfa, #ecfdf5); text-align: center; }
      .cta-content { max-width: 600px; margin: 0 auto; }
      .cta-content h2 { font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem, 3vw, 2.4rem); }
      .cta-content p { margin-top: 12px; color: var(--muted); font-size: 1.1rem; }
      .cta-actions { margin-top: 24px; display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }

      .site-footer { border-top: 1px solid rgba(13,148,136,0.1); padding: 28px 0; color: var(--muted); font-size: 0.88rem; text-align: center; }
      .float-wa { position: fixed; bottom: 24px; right: 24px; z-index: 60; width: 60px; height: 60px; border-radius: 50%; background: #25d366; color: #fff; display: grid; place-items: center; box-shadow: 0 6px 20px rgba(37,211,102,0.4); text-decoration: none; font-size: 1.7rem; transition: all 0.3s ease; }
      .float-wa:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,0.5); }

      @media (max-width: 980px) { .hero-grid { grid-template-columns: 1fr; } .services-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .benefits-grid { grid-template-columns: 1fr; } .menu a:not(.btn) { display: none; } .hero-visual { order: -1; } }
      @media (max-width: 640px) { .hero { padding: 48px 0 36px; } section { padding: 48px 0; } .services-grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand">
          <span class="logo-icon"><img src="https://static.wixstatic.com/media/ab417b_1cde5002e62141fbba56fe70a6f12f17~mv2.png/v1/crop/x_1333,y_357,w_3094,h_2478/fill/w_588,h_472,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/C%C3%83%C2%B3pia_de_Sem_nome.png" alt="Cão de Estrelas" /></span>
          <span class="brand-text">Cão de <span>Estrelas</span></span>
        </a>
        <nav class="menu" aria-label="Navegação principal">
          <a href="/">Início</a>
          <a href="/banho-em-moema">Banho</a>
          <a href="/tosa-em-moema">Tosa</a>
          <a href="/veterinario-moema">Veterinário</a>
          <a class="btn btn-primary" href="https://wa.me/5511942891718?text=Olá! Gostaria de agendar um banho em Moema">Agendar</a>
        </nav>
      </div>
    </header>

    <main>
      <section id="inicio" class="hero">
        <div class="container hero-grid">
          <div>
            <span class="badge">🛁 Banho completo</span>
            <h1>Banho em <em>Moema</em> com carinho e profissionalismo</h1>
            <p class="hero-desc">Seu cão merece um banho de qualidade, com produtos seguros, secagem cuidadosa e finalização cheirosa. No Cão de Estrelas, cada pet é tratado com amor.</p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="https://wa.me/5511942891718?text=Olá! Gostaria de agendar um banho em Moema">Agendar banho</a>
              <a class="btn btn-secondary" href="#servicos">Ver serviços</a>
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-img-wrap">
              <img src="https://images.unsplash.com/photo-1601758228041-f3b2795255f1?auto=format&fit=crop&w=1200&q=80" alt="Cachorro feliz no banho" loading="lazy" />
              <div class="hero-img-overlay"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="beneficios">
        <div class="container">
          <div class="section-header">
            <div class="section-tag">Por que escolher o Cão de Estrelas</div>
            <h2 class="section-title">Banho feito com cuidado e segurança</h2>
          </div>
          <div class="benefits-grid">
            <div class="benefit-card">
              <div class="benefit-icon">🧴</div>
              <div>
                <h3>Produtos de qualidade</h3>
                <p>Usamos shampoos e condicionadores específicos para cada tipo de pelagem, garantindo limpeza profunda sem irritações.</p>
              </div>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">💨</div>
              <div>
                <h3>Secagem cuidadosa</h3>
                <p>Secagem em ambiente aquecido com temperatura controlada para seu pet não ficar com frio ou desconforto.</p>
              </div>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">✨</div>
              <div>
                <h3>Finalização cheirosa</h3>
                <p>Perfume suave e duradouro deixa seu pet cheirando muito bem por dias após o atendimento.</p>
              </div>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">🩺</div>
              <div>
                <h3>Avaliação gratuita</h3>
                <p>Enquanto seu pet toma banho, fazemos uma verificação rápida de pele, ouvidos e pelagem para garantir a saúde dele.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="servicos">
        <div class="container">
          <div class="section-header">
            <div class="section-tag">Serviços relacionados</div>
            <h2 class="section-title">Combine banho com outros serviços</h2>
            <p class="section-desc">Tornamos o banho ainda mais completo com nossos serviços extras que seu pet merece.</p>
          </div>
          <div class="services-grid">
            <article class="service-card">
              <div class="service-icon">🛁</div>
              <h3>Banho completo</h3>
              <p>Limpeza profunda, secagem cuidadosa e finalização cheirosa.</p>
              <div class="service-price">A partir de R$ 45</div>
            </article>
            <article class="service-card">
              <div class="service-icon">✂️</div>
              <h3>Tosa higiênica</h3>
              <p>Máquina ou tesoura, respeitando o conforto e estilo do seu pet.</p>
              <div class="service-price">A partir de R$ 55</div>
            </article>
            <article class="service-card">
              <div class="service-icon">💧</div>
              <h3>Hidratação capilar</h3>
              <p>Tratamento para pelagem macia, brilhante e com menos nós.</p>
              <div class="service-price">A partir de R$ 65</div>
            </article>
          </div>
        </div>
      </section>

      <section id="cta">
        <div class="container">
          <div class="cta-content">
            <div class="section-tag" style="justify-content:center;">Agendamento</div>
            <h2>Agende o banho do seu cão agora</h2>
            <p>Fale diretamente com nosso WhatsApp e garanta um horário para seu melhor amigo.</p>
            <div class="cta-actions">
              <a class="btn btn-primary" href="https://wa.me/5511942891718?text=Olá! Gostaria de agendar um banho em Moema">Agendar pelo WhatsApp</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Cão de Estrelas Pet Shop — Rua Gaivota, 903 — Moema, São Paulo</p>
        <p style="margin-top:8px;"><a href="tel:+5511942891718" style="color:var(--c1);">📞 (11) 94289-1718</a></p>
      </div>
    </footer>

    <a class="float-wa" href="https://wa.me/5511942891718?text=Olá! Gostaria de informações sobre banho em Moema" aria-label="Contato WhatsApp">💬</a>
  </body>
</html>